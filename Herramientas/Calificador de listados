// ═══════════════════════════════════════════════════════
//  COLUMN DETECTION
// ═══════════════════════════════════════════════════════
function detectCols(row) {
  const keys = Object.keys(row);
  const find = (...terms) => keys.find(k => terms.some(t => k.toLowerCase().includes(t))) || '';
  return {
    empresa: find('empresa','company','name'),
    pais:    find('país','pais','country','land'),
    stand:   find('stand'),
    web:     find('web','página','page','site'),
    email:   find('correo','email','mail'),
  };
}

// ═══════════════════════════════════════════════════════
//  SCORING
// ═══════════════════════════════════════════════════════
function scoreRow(nombre, web) {
  const txt = (String(nombre) + ' ' + String(web)).toLowerCase();
  const found = keywords.filter(kw => txt.includes(kw));
  return { score: found.length, kws: found.slice(0, 8) };
}

// ═══════════════════════════════════════════════════════
//  MAIN FILTER
// ═══════════════════════════════════════════════════════
function runFilter() {
  if (!rawData.length) { showAlert('⚠️ Carga primero un archivo o usa los datos de ejemplo.', 'error'); return; }

  setProgress(20);

  const cols = detectCols(rawData[0]);
  if (!cols.empresa || !cols.pais) {
    showAlert('❌ No se detectaron columnas de empresa/país. Verifica el formato del Excel.', 'error');
    return;
  }

  const targetSet = new Set(selectedCountries.map(c => c.trim().toLowerCase()));
  setProgress(40);

  filteredData = rawData
    .filter(row => {
      const pais = String(row[cols.pais] || '').trim();
      return targetSet.has(pais.toLowerCase());
    })
    .map(row => {
      const pais_raw = String(row[cols.pais] || '').trim();
      const { score, kws } = scoreRow(row[cols.empresa], row[cols.web] || '');
      return {
        empresa: String(row[cols.empresa] || '').trim(),
        pais_raw,
        pais:    COUNTRY_NORMALIZE[pais_raw] || pais_raw,
        stand:   String(row[cols.stand] || '').replace('Stand:', '').trim(),
        web:     String(row[cols.web] || '').trim(),
        email:   String(row[cols.email] || '').trim(),
        score,
        kws,
      };
    })
    .sort((a, b) => b.score - a.score);

  setProgress(80);

  // Populate country select
  const countries = [...new Set(filteredData.map(r => r.pais))].sort();
  const sel = document.getElementById('filterCountry');
  sel.innerHTML = '<option value="">Todos los países</option>';
  countries.forEach(c => {
    const opt = document.createElement('option'); opt.value = c; opt.textContent = c; sel.appendChild(opt);
  });

  setProgress(100);

  setTimeout(() => {
    document.getElementById('progressWrap').style.display = 'none';
    showStats();
    renderTable();
    document.getElementById('resultsPanel').style.display = 'block';
    document.getElementById('resultsPanel').scrollIntoView({ behavior:'smooth', block:'start' });
  }, 400);
}

// ═══════════════════════════════════════════════════════
//  STATS
// ═══════════════════════════════════════════════════════
function showStats() {
  const relevant = filteredData.filter(r => r.score > 0).length;
  const countries = [...new Set(filteredData.map(r => r.pais))].length;
  const highPrio  = filteredData.filter(r => r.score >= 3).length;

  document.getElementById('statsStrip').innerHTML = `
    <div class="stat"><div class="num">${filteredData.length}</div><div class="lbl">Empresas filtradas</div></div>
    <div class="stat"><div class="num">${relevant}</div><div class="lbl">Con keywords relevantes</div></div>
    <div class="stat"><div class="num">${highPrio}</div><div class="lbl">Alta prioridad (3+ pts)</div></div>
    <div class="stat"><div class="num">${countries}</div><div class="lbl">Países representados</div></div>
  `;
}

// ═══════════════════════════════════════════════════════
//  TABLE RENDER
// ═══════════════════════════════════════════════════════
function getDisplayData() {
  const countryFilter = document.getElementById('filterCountry').value;
  const scoreFilter   = parseInt(document.getElementById('filterScore').value) || 0;
  const search        = document.getElementById('searchInput').value.toLowerCase();

  let data = filteredData.filter(r => {
    if (countryFilter && r.pais !== countryFilter) return false;
    if (scoreFilter && r.score < scoreFilter) return false;
    if (search && !r.empresa.toLowerCase().includes(search) &&
        !r.web.toLowerCase().includes(search) &&
        !r.email.toLowerCase().includes(search)) return false;
    return true;
  });

  data = [...data].sort((a, b) => {
    const av = a[sortCol] ?? '', bv = b[sortCol] ?? '';
    const dir = sortDir === 'asc' ? 1 : -1;
    return typeof av === 'number' ? (av - bv) * dir : String(av).localeCompare(String(bv)) * dir;
  });

  return data;
}

function renderTable() {
  currentPage = 1;
  displayData = getDisplayData();
  renderPage();
  renderPagination();
  document.getElementById('resultSubtitle').textContent =
    `${displayData.length} empresas · ordenadas por relevancia`;
}

function renderPage() {
  const start = (currentPage - 1) * PAGE_SIZE;
  const page  = displayData.slice(start, start + PAGE_SIZE);
  const tbody = document.getElementById('tableBody');

  tbody.innerHTML = page.map(r => {
    const badge = `<span class="country-badge ${COUNTRY_CLASS[r.pais]||'c-xx'}">${r.pais}</span>`;
    const stars = r.score > 0
      ? `<span class="stars">${'★'.repeat(Math.min(r.score,5))}${'☆'.repeat(Math.max(0,5-r.score))}</span>`
      : `<span class="stars stars-0">—</span>`;
    const webLink = r.web ? `<a href="https://${r.web.replace(/^https?:\/\//,'')}" target="_blank">${r.web}</a>` : '—';
    const emailLink = r.email ? `<a href="mailto:${r.email}">${r.email}</a>` : '—';
    const kwChips = r.kws.length
      ? `<div class="kw-chips">${r.kws.map(k=>`<span class="kw-chip">${k}</span>`).join('')}</div>`
      : '—';
    return `<tr>
      <td class="empresa">${r.empresa}</td>
      <td>${badge}</td>
      <td><code style="font-size:.78rem;color:var(--grey-500)">${r.stand||'—'}</code></td>
      <td>${webLink}</td>
      <td>${emailLink}</td>
      <td style="text-align:center">${stars}</td>
      <td>${kwChips}</td>
    </tr>`;
  }).join('');
}

function renderPagination() {
  const totalPages = Math.ceil(displayData.length / PAGE_SIZE);
  if (totalPages <= 1) { document.getElementById('pagination').innerHTML = ''; return; }

  let html = `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;
  for (let i = 1; i <= totalPages; i++) {
    if (i===1||i===totalPages||Math.abs(i-currentPage)<=2)
      html += `<button class="page-btn ${i===currentPage?'active':''}" onclick="goPage(${i})">${i}</button>`;
    else if (Math.abs(i-currentPage)===3)
      html += `<span style="padding:0 .3rem;color:var(--grey-400)">…</span>`;
  }
  html += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===totalPages?'disabled':''}>›</button>`;
  document.getElementById('pagination').innerHTML = html;
}

function goPage(p) {
  const total = Math.ceil(displayData.length / PAGE_SIZE);
  if (p < 1 || p > total) return;
  currentPage = p;
  renderPage();
  renderPagination();
}

// ═══════════════════════════════════════════════════════
//  SORTING
// ═══════════════════════════════════════════════════════
function sortBy(col) {
  if (sortCol === col) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
  else { sortCol = col; sortDir = col === 'score' ? 'desc' : 'asc'; }

  document.querySelectorAll('thead th').forEach(th => {
    th.classList.remove('sort-asc','sort-desc');
  });
  const headers = { empresa:0, pais:1, stand:2, score:5 };
  const idx = headers[col];
  if (idx !== undefined) {
    const th = document.querySelectorAll('thead th')[idx];
    th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
  }
  renderTable();
}

// ═══════════════════════════════════════════════════════
//  DOWNLOADS
// ═══════════════════════════════════════════════════════
function downloadCSV() {
  const data = getDisplayData();
  const headers = ['Empresa','País','Stand','Web','Email','Puntuacion','Keywords'];
  const rows = data.map(r => [
    `"${r.empresa}"`, `"${r.pais}"`, `"${r.stand}"`,
    `"${r.web}"`, `"${r.email}"`, r.score, `"${r.kws.join(', ')}"`
  ]);
  const csv = [headers.join(','), ...rows.map(r=>r.join(','))].join('\n');
  const blob = new Blob(['\uFEFF'+csv], { type:'text/csv;charset=utf-8;' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `PLMA_CastillaLeon_${today()}.csv`;
  a.click();
}

function downloadXLSX() {
  const data = getDisplayData();
  const ws_data = [
    ['Empresa','País','Stand','Web','Email','Puntuación','Relevancia','Keywords detectadas'],
    ...data.map(r => [r.empresa, r.pais, r.stand, r.web, r.email, r.score,
      '★'.repeat(Math.min(r.score,5)), r.kws.join(', ')])
  ];
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet(ws_data);
  ws['!cols'] = [32,14,10,30,34,10,12,40].map(w=>({wch:w}));
  XLSX.utils.book_append_sheet(wb, ws, 'Filtro CyL');
  XLSX.writeFile(wb, `PLMA_CastillaLeon_${today()}.xlsx`);
}

function today() {
  return new Date().toISOString().slice(0,10).replace(/-/g,'');
}

