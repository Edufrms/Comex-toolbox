<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PLMA Filter Tool – Comextoolbox</title>

  <!-- SheetJS para leer Excel en el navegador -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

  <style>
    /* ── Variables ── */
    :root {
      --blue-900: #0d1f3c;
      --blue-800: #162d55;
      --blue-600: #1a4a8a;
      --blue-500: #2060b0;
      --blue-400: #3a7fd5;
      --blue-100: #ddeeff;
      --blue-50:  #f0f6ff;
      --grey-700: #374151;
      --grey-500: #6b7280;
      --grey-300: #d1d5db;
      --grey-100: #f3f4f6;
      --grey-50:  #f9fafb;
      --white:    #ffffff;
      --green:    #16a34a;
      --green-light: #dcfce7;
      --orange:   #ea580c;
      --orange-light: #ffedd5;
      --red:      #dc2626;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.08);
      --shadow-md: 0 4px 16px rgba(0,0,0,.10);
      --shadow-lg: 0 8px 32px rgba(13,31,60,.15);
      --radius:   10px;
      --font-head: 'Sora', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--grey-50);
      color: var(--grey-700);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* ── Google Fonts ── */
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

    /* ── Header ── */
    .site-header {
      background: var(--blue-900);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 2px solid var(--blue-600);
    }
    .logo {
      font-family: var(--font-head);
      font-weight: 800;
      font-size: 1.2rem;
      color: var(--white);
      letter-spacing: -.02em;
      text-decoration: none;
    }
    .logo span { color: var(--blue-400); }
    .header-badge {
      font-family: var(--font-mono);
      font-size: .7rem;
      background: var(--blue-600);
      color: var(--blue-100);
      padding: .25rem .7rem;
      border-radius: 99px;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    /* ── Hero ── */
    .hero {
      background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-800) 60%, var(--blue-600) 100%);
      padding: 4rem 2rem 3rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 110%, rgba(58,127,213,.25) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-tag {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: .72rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.2);
      color: var(--blue-100);
      padding: .3rem 1rem;
      border-radius: 99px;
      margin-bottom: 1.25rem;
    }
    .hero h1 {
      font-family: var(--font-head);
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      color: var(--white);
      line-height: 1.2;
      letter-spacing: -.03em;
      margin-bottom: .75rem;
    }
    .hero h1 em { color: var(--blue-400); font-style: normal; }
    .hero p {
      color: rgba(255,255,255,.75);
      font-size: 1.05rem;
      max-width: 580px;
      margin: 0 auto;
    }

    /* ── Main layout ── */
    .main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }

    /* ── Card ── */
    .card {
      background: var(--white);
      border-radius: var(--radius);
      box-shadow: var(--shadow-md);
      border: 1px solid var(--grey-300);
      overflow: hidden;
    }
    .card-header {
      background: var(--blue-50);
      border-bottom: 1px solid var(--grey-300);
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: .75rem;
    }
    .card-header .icon {
      width: 32px; height: 32px;
      background: var(--blue-600);
      border-radius: 8px;
      display: grid; place-items: center;
      color: white; font-size: 1rem; flex-shrink: 0;
    }
    .card-header h2 {
      font-family: var(--font-head);
      font-size: 1rem;
      font-weight: 700;
      color: var(--blue-900);
    }
    .card-header p { font-size: .82rem; color: var(--grey-500); }
    .card-body { padding: 1.5rem; }

    /* ── Step flow ── */
    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .step {
      background: var(--grey-50);
      border: 1px solid var(--grey-300);
      border-radius: var(--radius);
      padding: 1rem 1.25rem;
      display: flex; gap: .75rem; align-items: flex-start;
    }
    .step-num {
      width: 26px; height: 26px; flex-shrink: 0;
      background: var(--blue-600);
      color: white;
      border-radius: 50%;
      display: grid; place-items: center;
      font-family: var(--font-head);
      font-size: .78rem;
      font-weight: 700;
    }
    .step-text { font-size: .85rem; color: var(--grey-700); line-height: 1.5; }
    .step-text strong { color: var(--blue-900); }

    /* ── Config grid ── */
    .config-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 640px) { .config-grid { grid-template-columns: 1fr; } }

    .config-section h3 {
      font-family: var(--font-head);
      font-size: .88rem;
      font-weight: 700;
      color: var(--blue-900);
      margin-bottom: .6rem;
      display: flex; align-items: center; gap: .4rem;
    }

    /* ── Tag pills ── */
    .tags { display: flex; flex-wrap: wrap; gap: .4rem; }
    .tag {
      display: inline-flex; align-items: center; gap: .35rem;
      background: var(--blue-50);
      border: 1px solid var(--blue-100);
      color: var(--blue-800);
      border-radius: 99px;
      font-size: .78rem;
      padding: .2rem .7rem;
      cursor: pointer;
      transition: all .15s;
      user-select: none;
    }
    .tag:hover { background: var(--blue-100); }
    .tag.active {
      background: var(--blue-600);
      border-color: var(--blue-600);
      color: white;
    }
    .tag .remove { opacity: .6; font-size: .9rem; line-height: 1; }
    .tag.active .remove { opacity: 1; }

    /* ── Add tag input ── */
    .add-tag-row {
      display: flex; gap: .4rem; margin-top: .5rem;
    }
    .add-tag-row input {
      flex: 1;
      border: 1px solid var(--grey-300);
      border-radius: 6px;
      padding: .3rem .7rem;
      font-size: .82rem;
      font-family: var(--font-body);
      outline: none;
      transition: border .15s;
    }
    .add-tag-row input:focus { border-color: var(--blue-400); }
    .add-tag-row button {
      background: var(--blue-600);
      color: white;
      border: none;
      border-radius: 6px;
      padding: .3rem .8rem;
      font-size: .82rem;
      cursor: pointer;
      font-family: var(--font-body);
      font-weight: 600;
      transition: background .15s;
    }
    .add-tag-row button:hover { background: var(--blue-500); }

    /* ── Drop zone ── */
    .dropzone {
      border: 2px dashed var(--grey-300);
      border-radius: var(--radius);
      padding: 2.5rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: all .2s;
      background: var(--grey-50);
      margin-bottom: 1.25rem;
    }
    .dropzone:hover, .dropzone.drag-over {
      border-color: var(--blue-400);
      background: var(--blue-50);
    }
    .dropzone.has-file {
      border-color: var(--green);
      background: var(--green-light);
    }
    .dropzone-icon { font-size: 2.5rem; margin-bottom: .6rem; }
    .dropzone p { font-size: .9rem; color: var(--grey-500); }
    .dropzone p strong { color: var(--blue-600); }
    .dropzone .file-name {
      font-family: var(--font-mono);
      font-size: .82rem;
      color: var(--green);
      margin-top: .4rem;
      font-weight: 500;
    }
    #fileInput { display: none; }

    /* ── Demo button ── */
    .demo-btn {
      width: 100%;
      background: var(--grey-100);
      border: 1px solid var(--grey-300);
      border-radius: 8px;
      padding: .7rem;
      font-size: .85rem;
      font-family: var(--font-body);
      color: var(--grey-700);
      cursor: pointer;
      margin-bottom: 1.25rem;
      transition: all .15s;
      display: flex; align-items: center; justify-content: center; gap: .5rem;
    }
    .demo-btn:hover { background: var(--grey-300); }

    /* ── Run button ── */
    .run-btn {
      width: 100%;
      background: linear-gradient(135deg, var(--blue-600), var(--blue-500));
      color: white;
      border: none;
      border-radius: 8px;
      padding: .9rem 1.5rem;
      font-family: var(--font-head);
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all .2s;
      display: flex; align-items: center; justify-content: center; gap: .6rem;
      box-shadow: 0 4px 14px rgba(26,74,138,.35);
    }
    .run-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(26,74,138,.45); }
    .run-btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }

    /* ── Progress ── */
    .progress-bar-wrap {
      height: 4px;
      background: var(--grey-200);
      border-radius: 99px;
      overflow: hidden;
      margin: 1rem 0;
      display: none;
    }
    .progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--blue-600), var(--blue-400));
      border-radius: 99px;
      width: 0%;
      transition: width .4s ease;
    }

    /* ── Results panel ── */
    .results-panel { margin-top: 2rem; display: none; }

    /* ── Stats strip ── */
    .stats-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: .75rem;
      margin-bottom: 1.5rem;
    }
    .stat {
      background: var(--white);
      border: 1px solid var(--grey-300);
      border-radius: var(--radius);
      padding: 1rem;
      text-align: center;
      box-shadow: var(--shadow-sm);
    }
    .stat .num {
      font-family: var(--font-head);
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--blue-600);
      line-height: 1;
    }
    .stat .lbl { font-size: .78rem; color: var(--grey-500); margin-top: .2rem; }

    /* ── Filters bar ── */
    .filters-bar {
      display: flex; gap: .6rem; flex-wrap: wrap; align-items: center;
      margin-bottom: 1rem;
    }
    .filters-bar select,
    .filters-bar input {
      border: 1px solid var(--grey-300);
      border-radius: 6px;
      padding: .4rem .7rem;
      font-size: .83rem;
      font-family: var(--font-body);
      outline: none;
      background: var(--white);
      transition: border .15s;
    }
    .filters-bar select:focus,
    .filters-bar input:focus { border-color: var(--blue-400); }
    .filters-bar input { min-width: 180px; }

    /* ── Table ── */
    .table-wrap {
      overflow-x: auto;
      border-radius: var(--radius);
      border: 1px solid var(--grey-300);
      box-shadow: var(--shadow-sm);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: .83rem;
    }
    thead tr { background: var(--blue-900); }
    thead th {
      padding: .65rem 1rem;
      text-align: left;
      color: white;
      font-family: var(--font-head);
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .03em;
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
    }
    thead th:hover { background: var(--blue-800); }
    thead th .sort-arrow { opacity: .4; margin-left: .3rem; font-size: .7rem; }
    thead th.sort-asc .sort-arrow::after { content: '▲'; opacity: 1; }
    thead th.sort-desc .sort-arrow::after { content: '▼'; opacity: 1; }
    thead th:not(.sort-asc):not(.sort-desc) .sort-arrow::after { content: '⇅'; }

    tbody tr { border-bottom: 1px solid var(--grey-100); transition: background .1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--blue-50); }
    tbody td { padding: .6rem 1rem; color: var(--grey-700); vertical-align: top; }
    tbody td.empresa { font-weight: 600; color: var(--blue-900); }
    tbody td a { color: var(--blue-500); text-decoration: none; }
    tbody td a:hover { text-decoration: underline; }

    /* Priority stars */
    .stars { color: #f59e0b; font-size: .9rem; white-space: nowrap; }
    .stars-0 { color: var(--grey-300); }

    /* Country badge */
    .country-badge {
      display: inline-block;
      font-size: .72rem;
      font-weight: 600;
      padding: .15rem .55rem;
      border-radius: 99px;
      white-space: nowrap;
    }
    .c-nl { background: #ffedd5; color: #9a3412; }
    .c-be { background: #dbeafe; color: #1e40af; }
    .c-uk { background: #f3e8ff; color: #6b21a8; }
    .c-ie { background: #dcfce7; color: #15803d; }
    .c-lu { background: #fce7f3; color: #9d174d; }
    .c-xx { background: var(--grey-100); color: var(--grey-700); }

    /* ── Keywords chip ── */
    .kw-chips { display: flex; flex-wrap: wrap; gap: .25rem; }
    .kw-chip {
      font-size: .68rem;
      background: var(--blue-50);
      color: var(--blue-700);
      border-radius: 4px;
      padding: .1rem .35rem;
      font-family: var(--font-mono);
    }

    /* ── Download bar ── */
    .download-bar {
      margin-top: 1.25rem;
      display: flex; gap: .75rem; flex-wrap: wrap; align-items: center;
      justify-content: flex-end;
    }
    .dl-btn {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: .6rem 1.2rem;
      border-radius: 8px;
      font-family: var(--font-head);
      font-size: .85rem;
      font-weight: 700;
      cursor: pointer;
      border: none;
      transition: all .15s;
    }
    .dl-btn-csv {
      background: var(--green-light);
      color: var(--green);
      border: 1px solid #bbf7d0;
    }
    .dl-btn-csv:hover { background: #bbf7d0; }
    .dl-btn-xlsx {
      background: linear-gradient(135deg, var(--blue-600), var(--blue-500));
      color: white;
      box-shadow: 0 3px 10px rgba(26,74,138,.3);
    }
    .dl-btn-xlsx:hover { transform: translateY(-1px); }

    /* ── Alert ── */
    .alert {
      padding: .8rem 1.1rem;
      border-radius: 8px;
      font-size: .87rem;
      margin-bottom: 1rem;
      display: none;
    }
    .alert-error { background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; }
    .alert-info  { background: var(--blue-50); border: 1px solid var(--blue-100); color: var(--blue-800); }

    /* ── Pagination ── */
    .pagination {
      display: flex; justify-content: center; align-items: center; gap: .4rem;
      margin-top: 1rem; flex-wrap: wrap;
    }
    .page-btn {
      width: 32px; height: 32px;
      border: 1px solid var(--grey-300);
      background: var(--white);
      border-radius: 6px;
      display: grid; place-items: center;
      cursor: pointer;
      font-size: .82rem;
      transition: all .1s;
      font-family: var(--font-body);
    }
    .page-btn:hover { background: var(--blue-50); border-color: var(--blue-400); }
    .page-btn.active { background: var(--blue-600); color: white; border-color: var(--blue-600); }
    .page-btn:disabled { opacity: .4; cursor: not-allowed; }

    /* ── Footer ── */
    footer {
      background: var(--blue-900);
      color: rgba(255,255,255,.5);
      text-align: center;
      padding: 1.5rem;
      font-size: .8rem;
    }
    footer a { color: var(--blue-400); text-decoration: none; }
  </style>
</head>
<body>

<!-- Header -->
<header class="site-header">
  <a href="#" class="logo">comex<span>toolbox</span></a>
  <span class="header-badge">PLMA Filter Tool</span>
</header>

<!-- Hero -->
<section class="hero">
  <div class="hero-tag">🌍 Herramienta de exportación</div>
  <h1>Filtro PLMA para<br><em>Marca del Distribuidor</em></h1>
  <p>Sube el listado oficial de PLMA, selecciona los países objetivo y obtén al instante las empresas más relevantes para tu estrategia exportadora.</p>
</section>

<!-- Main -->
<main class="main">

  <!-- Alert -->
  <div class="alert alert-error" id="alertBox"></div>

  <!-- Upload & Config card -->
  <div class="card" style="margin-bottom:1.5rem">
    <div class="card-header">
      <div class="icon">⚙️</div>
      <div>
        <h2>Configuración del filtro</h2>
        <p>Define países objetivo, palabras clave y sube tu archivo PLMA</p>
      </div>
    </div>
    <div class="card-body">

      <!-- Steps -->
      <div class="steps">
        <div class="step"><span class="step-num">1</span><span class="step-text"><strong>Selecciona países</strong> objetivo de tu estrategia de exportación</span></div>
        <div class="step"><span class="step-num">2</span><span class="step-text"><strong>Ajusta las keywords</strong> según los productos que exportas</span></div>
        <div class="step"><span class="step-num">3</span><span class="step-text"><strong>Sube el Excel</strong> descargado de worldofprivatelabel.com</span></div>
        <div class="step"><span class="step-num">4</span><span class="step-text"><strong>Analiza y descarga</strong> los resultados filtrados y priorizados</span></div>
      </div>

      <!-- Config grid -->
      <div class="config-grid">

        <!-- Countries -->
        <div class="config-section">
          <h3>🌍 Países objetivo</h3>
          <div class="tags" id="countryTags"></div>
          <div class="add-tag-row" style="margin-top:.5rem">
            <input type="text" id="countryInput" placeholder="Ej: Germany" />
            <button onclick="addCountry()">+ Añadir</button>
          </div>
        </div>

        <!-- Keywords -->
        <div class="config-section">
          <h3>🔑 Palabras clave de relevancia</h3>
          <div class="tags" id="keywordTags"></div>
          <div class="add-tag-row" style="margin-top:.5rem">
            <input type="text" id="keywordInput" placeholder="Ej: wine, gourmet..." />
            <button onclick="addKeyword()">+ Añadir</button>
          </div>
        </div>

      </div>

      <!-- Upload area -->
      <div class="dropzone" id="dropzone" onclick="document.getElementById('fileInput').click()">
        <div class="dropzone-icon">📊</div>
        <p><strong>Haz clic o arrastra aquí</strong> tu archivo PLMA (.xlsx)</p>
        <p style="font-size:.78rem;margin-top:.3rem">Descargable desde worldofprivatelabel.com (sólo acceso con registro)</p>
        <div class="file-name" id="fileName"></div>
      </div>
      <input type="file" id="fileInput" accept=".xlsx,.xls" onchange="handleFile(this.files[0])" />

      <!-- Demo data button -->
      <button class="demo-btn" onclick="loadDemo()">
        🎭 <span>Probar con datos de ejemplo (sin necesidad de archivo)</span>
      </button>

      <!-- Progress -->
      <div class="progress-bar-wrap" id="progressWrap">
        <div class="progress-bar" id="progressBar"></div>
      </div>

      <!-- Run -->
      <button class="run-btn" id="runBtn" onclick="runFilter()" disabled>
        🔍 Ejecutar filtro
      </button>

    </div>
  </div>

  <!-- Results -->
  <div class="results-panel" id="resultsPanel">

    <!-- Stats -->
    <div class="stats-strip" id="statsStrip"></div>

    <!-- Table card -->
    <div class="card">
      <div class="card-header">
        <div class="icon">📋</div>
        <div>
          <h2>Empresas encontradas</h2>
          <p id="resultSubtitle">Ordenadas por relevancia</p>
        </div>
      </div>
      <div class="card-body">
        <div class="filters-bar">
          <select id="filterCountry" onchange="renderTable()">
            <option value="">Todos los países</option>
          </select>
          <select id="filterScore" onchange="renderTable()">
            <option value="">Cualquier relevancia</option>
            <option value="3">Alta (3+ pts)</option>
            <option value="2">Media (2+ pts)</option>
            <option value="1">Con keywords (1+ pts)</option>
          </select>
          <input type="text" id="searchInput" placeholder="🔎 Buscar empresa..." oninput="renderTable()" />
        </div>
        <div class="table-wrap">
          <table id="resultsTable">
            <thead>
              <tr>
                <th onclick="sortBy('empresa')">Empresa <span class="sort-arrow"></span></th>
                <th onclick="sortBy('pais')">País <span class="sort-arrow"></span></th>
                <th onclick="sortBy('stand')">Stand <span class="sort-arrow"></span></th>
                <th>Web</th>
                <th>Email</th>
                <th onclick="sortBy('score')">Pts <span class="sort-arrow"></span></th>
                <th>Keywords</th>
              </tr>
            </thead>
            <tbody id="tableBody"></tbody>
          </table>
        </div>
        <div class="pagination" id="pagination"></div>
        <div class="download-bar">
          <button class="dl-btn dl-btn-csv" onclick="downloadCSV()">⬇ Descargar CSV</button>
